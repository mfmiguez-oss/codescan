# Copy to .env and fill in. Never commit real secrets.

# --- AI providers (multi-supplier harness; set the one(s) you route to) ---
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI, or any OpenAI-compatible supplier (also set OPENAI_BASE_URL for those):
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.together.xyz/v1
# Google Gemini:
GEMINI_API_KEY=

# --- Bitbucket Data Center / Server (on-prem) ---
BITBUCKET_BASE_URL=https://bitbucket.internal.example.com
BITBUCKET_TOKEN=              # HTTP access token (Bearer)

# --- GitHub (alternative repo source: github.com or GHES) ---
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=                 # personal access token (repo:read)

# --- Snyk ---
SNYK_API_URL=https://snyk.internal.example.com/api   # or https://api.snyk.io
SNYK_TOKEN=
SNYK_ORG_ID=

# --- JFrog Xray ---
XRAY_BASE_URL=https://artifactory.internal.example.com/xray
XRAY_TOKEN=

# --- ServiceNow (Vulnerability Response) ---
SERVICENOW_INSTANCE=https://acme.service-now.com
SERVICENOW_USER=
SERVICENOW_PASSWORD=

# --- Web UI / API (optional) ---
# If set, every /api/* request must present this token (Authorization: Bearer,
# X-API-Token header, or visit /?token=... once to set a cookie). Unset = no auth
# (front the UI with your SSO / reverse proxy). Defense in depth, not a substitute.
CODESCAN_API_TOKEN=
# CODESCAN_LOG_LEVEL=INFO       # DEBUG for per-task model routing + verbose logs

# --- HashiCorp Vault (optional; only the bootstrap creds go here — the app
#     secrets above are then fetched FROM Vault). See config vault.enabled. ---
VAULT_ADDR=https://vault.internal.example.com:8200
VAULT_TOKEN=                  # for vault.auth: token
# VAULT_ROLE_ID=              # for vault.auth: approle
# VAULT_SECRET_ID=
